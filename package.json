{
  "name": "blather-round-modder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "compile": "tsc -p ./src/tsconfig.json && $npm_execpath copyfiles",
    "copyfiles": "cpy './src/**/*' '!**/*.ts' dist --parents",
    "migrate": "$npm_execpath migrate:run && $npm_execpath migrate:seed",
    "migrate:seed": "$npm_execpath prisma db seed",
    "migrate:generate": "$npm_execpath prisma migrate dev",
    "migrate:run": "$npm_execpath prisma migrate deploy",
    "migrate:revert": "$npm_execpath primsa migrate resolve --rolled-back"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm ./src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "argon2": "^0.31.2",
    "autoprefixer": "^10.4.16",
    "common-tags": "^1.8.2",
    "cpy-cli": "^5.0.0",
    "jszip": "^3.10.1",
    "next": "^14.0.2",
    "nextjs-toploader": "^1.6.4",
    "postcss": "^8.4.31",
    "prisma": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reflect-metadata": "^0.1.13",
    "server-only": "^0.0.1",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.6",
    "tailwindcss": "^3.3.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/common-tags": "^1.8.4",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.53.0",
    "eslint-config-next": "^14.0.2",
    "prettier": "^3.1.0"
  }
}
